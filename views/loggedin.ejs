<%- include('partials/admin'); -%>

<div class="page-content">
    <div class="compose">
        <h2><span>Update</span> Home</h2>
    </div>
    <div class="admin-form-card">
        <form action="/edithome" method="post">
            <div class="mb-3">
                <label class="form-label">Home Title</label>
                <input class="form-control pushi" type="text" name="homeTitle" placeholder="Enter home title">
            </div>
            <div class="mb-3">
                <label class="form-label">About</label>
                <textarea class="form-control" name="aboutBody" rows="6" placeholder="Write the about section..."></textarea>
            </div>
            <p class="note"><i><span>Note:</span> This is an admin page — only admins can make changes to this site.</i></p>
            <button class="btn btn-primary postbutton" type="submit">UPDATE</button>
        </form>
    </div>
</div>

<%- include('partials/footer'); -%>
