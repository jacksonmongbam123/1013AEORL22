<%- include('partials/admin'); -%>

<div class="page-content">
    <div class="blogtitle">
        <h2><span>Manage</span> Bookings</h2>
        <p style="color:var(--text-muted);">Appointment requests submitted through the booking form.</p>
    </div>

    <% if (bookings.length === 0) { %>
    <div class="about-card text-center py-5">
        <i class="fa-solid fa-calendar-check" style="font-size:2.5rem; color:var(--text-muted); margin-bottom:1rem;"></i>
        <p>No bookings yet.</p>
    </div>
    <% } %>

    <div style="display:flex; flex-direction:column; gap:1rem;">
    <% for(var i=0; i<bookings.length; i++) { %>
    <div class="contact-entry">
        <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:0.5rem; margin-bottom:0.5rem;">
            <div>
                <h3 style="margin:0;"><%= bookings[i].name %></h3>
                <p style="color:var(--text-muted); font-size:0.85rem; margin:0.25rem 0 0;">
                    <i class="fa-solid fa-briefcase" style="color:var(--primary); margin-right:5px;"></i><%= bookings[i].service %>
                </p>
            </div>
            <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                <span style="background:<%= bookings[i].status==='Confirmed' ? '#dcfce7' : bookings[i].status==='Cancelled' ? '#fee2e2' : '#fef9c3' %>; color:<%= bookings[i].status==='Confirmed' ? '#166534' : bookings[i].status==='Cancelled' ? '#991b1b' : '#854d0e' %>; padding:0.2rem 0.75rem; border-radius:20px; font-size:0.8rem; font-weight:700;">
                    <%= bookings[i].status %>
                </span>
            </div>
        </div>

        <p><i class="fa-solid fa-envelope" style="color:var(--primary); margin-right:6px;"></i><%= bookings[i].email %></p>
        <% if(bookings[i].phone){ %><p><i class="fa-solid fa-phone" style="color:var(--primary); margin-right:6px;"></i><%= bookings[i].phone %></p><% } %>
        <p>
            <i class="fa-solid fa-calendar" style="color:var(--primary); margin-right:6px;"></i><%= bookings[i].date %>
            <% if(bookings[i].time){ %> &nbsp;at&nbsp; <i class="fa-solid fa-clock" style="color:var(--primary); margin-right:6px;"></i><%= bookings[i].time %><% } %>
        </p>
        <% if(bookings[i].message){ %>
        <div class="msg"><p><%= bookings[i].message %></p></div>
        <% } %>

        <div style="display:flex; gap:0.75rem; align-items:center; margin-top:0.75rem; flex-wrap:wrap;">
            <form action="/admin-books/status/<%= bookings[i]._id %>" method="post" style="display:inline-flex; align-items:center; gap:0.5rem;">
                <select name="status" class="form-control" style="padding:0.3rem 0.6rem; font-size:0.82rem; width:auto;">
                    <option value="Pending" <%= bookings[i].status==='Pending' ? 'selected' : '' %>>Pending</option>
                    <option value="Confirmed" <%= bookings[i].status==='Confirmed' ? 'selected' : '' %>>Confirmed</option>
                    <option value="Cancelled" <%= bookings[i].status==='Cancelled' ? 'selected' : '' %>>Cancelled</option>
                </select>
                <button type="submit" class="btn btn-sm" style="background:var(--primary-light); color:var(--primary); border:1px solid var(--primary); font-weight:600; font-size:0.82rem; padding:0.3rem 0.8rem; border-radius:6px;">Update</button>
            </form>
            <form action="/admin-books/delete/<%= bookings[i]._id %>" method="post" onsubmit="return confirm('Delete this booking?')">
                <button type="submit" class="btn btn-sm" style="background:#fee2e2; color:#991b1b; border:1px solid #fca5a5; font-weight:600; font-size:0.82rem; padding:0.3rem 0.8rem; border-radius:6px; display:inline-flex; align-items:center; gap:0.3rem;">
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </form>
        </div>
    </div>
    <% } %>
    </div>
</div>

<%- include('partials/footer'); -%>
