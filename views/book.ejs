<%- include('partials/header'); -%>

<div class="page-content">
    <!-- Redesigned Header Section -->
    <div class="page-header">
        <div class="page-header-content">
            <p class="page-label">Schedule a Session</p>
            <h1>Book an <span>Appointment</span></h1>
            <p class="page-subtitle">Fill in the form below and we'll get back to you shortly to confirm your session.</p>
        </div>
    </div>

    <div class="contact-card">
        <form action="/book" method="post">
            <div class="row">
                <div class="col-md-6">
                    <div class="pushi">
                        <label class="form-label">Full Name</label>
                        <input class="form-control" type="text" name="bookName" placeholder="Your full name" required>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="pushi">
                        <label class="form-label">Email Address</label>
                        <input class="form-control" type="email" name="bookEmail" placeholder="your@email.com" required>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="pushi">
                        <label class="form-label">Phone Number</label>
                        <input class="form-control" type="tel" name="bookPhone" placeholder="e.g. 8837092377">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="pushi">
                        <label class="form-label">Service</label>
                        <select class="form-control" name="bookService" required>
                            <option value="">— Select a service —</option>
                            <option value="Web Development">Web Development</option>
                            <option value="UI/UX Design">UI/UX Design</option>
                            <option value="Consultation">Consultation</option>
                            <option value="Mentorship">Mentorship</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="pushi">
                        <label class="form-label">Preferred Date</label>
                        <input class="form-control" type="date" name="bookDate" required>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="pushi">
                        <label class="form-label">Preferred Time</label>
                        <input class="form-control" type="time" name="bookTime">
                    </div>
                </div>
                <div class="col-12">
                    <div class="pushi">
                        <label class="form-label">Message / Notes</label>
                        <textarea class="form-control" name="bookMessage" rows="4" placeholder="Tell us more about what you need..."></textarea>
                    </div>
                </div>
            </div>
            <p class="note"><i>We'll confirm your appointment via email within 24 hours.</i></p>
            <button type="submit" class="btn btn-admin-style postbutton"><i class="fa-regular fa-calendar-check me-1"></i> Book Appointment</button>
        </form>
    </div>
</div>

<%- include('partials/footer'); -%>
