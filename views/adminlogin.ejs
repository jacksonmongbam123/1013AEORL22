<%- include('partials/header'); -%>

<style>
.auth-wrapper{display:flex;min-height:100vh;margin:0;padding:0;align-items:center;justify-content:center;background:var(--bg,#f9fafb);}
.auth-wrapper .auth-card{max-width:420px;width:100%;padding:3rem 2.5rem;}
@media(max-width:768px){.auth-wrapper{padding:2rem 1.25rem;}.auth-wrapper .auth-card{padding:2rem 1.25rem;}}
</style>

<div class="auth-wrapper">
    <div class="auth-card">
            <% if (loginError) { %>
            <div style="background:#FEF2F2;border:1.5px solid #FECACA;border-radius:8px;padding:0.75rem 1rem;margin-bottom:1.5rem;display:flex;align-items:center;gap:0.6rem;">
                <i class="fa-solid fa-circle-exclamation" style="color:#DC2626;font-size:1rem;"></i>
                <span style="color:#DC2626;font-size:clamp(0.83rem,1.3vw,0.9rem);font-weight:600;">Invalid username or password. Please try again.</span>
            </div>
            <% } %>
            <h2>Admin <span>Login</span></h2>
            <form action="/adminlogin" method="post">
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="username" placeholder="admin@example.com" required>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="Your password" required>
                </div>
                <button type="submit" class="btn-auth btn-auth--login">Login</button>
                <p class="auth-link">Don't have an account? <a href="/adminregister">Sign up</a></p>
            </form>
    </div>
</div>

<%- include('partials/footer'); -%>
