<%- include('partials/admin'); -%>

<div class="page-content">
    <div class="admin-list-header">
        <div>
            <h2><span>Contact</span> Messages</h2>
            <p>Messages submitted through the contact form.</p>
        </div>
        <% const unreadCount = contactDetails.filter(c => !c.read).length; %>
        <% if (unreadCount > 0) { %>
            <form action="/getcontact/readall" method="post" style="margin:0;">
                <button type="submit" class="btn-mark-all-read">
                    <i class="fa-solid fa-check-double"></i> Mark all as read (<%= unreadCount %>)
                </button>
            </form>
        <% } %>
    </div>

    <% if(contactDetails.length === 0) { %>
        <div class="admin-empty-state">
            <i class="fa-solid fa-inbox"></i>
            <p>No contact messages yet.</p>
        </div>
    <% } %>

    <div class="admin-list-stack">
    <% for(var i=0; i<contactDetails.length; i++) { %>
        <div class="contact-entry <%= contactDetails[i].read ? '' : 'contact-entry--unread' %>">
            <div class="admin-list-card" style="margin-bottom:0.5rem;">
                <h3 style="margin:0;">
                    <% if (!contactDetails[i].read) { %>
                        <span class="contact-unread-dot"></span>
                    <% } %>
                    <%=contactDetails[i].name%>
                </h3>
                <div class="admin-card-actions">
                    <span class="meta"><%=contactDetails[i].time%> &nbsp;<%=contactDetails[i].hour%>:<%=contactDetails[i].minute%></span>
                    <% if (!contactDetails[i].read) { %>
                        <form action="/getcontact/read/<%=contactDetails[i]._id%>" method="post" style="margin:0;">
                            <button type="submit" class="btn-mark-read">
                                <i class="fa-solid fa-check"></i> Mark read
                            </button>
                        </form>
                    <% } %>
                    <form action="/getcontact/delete/<%=contactDetails[i]._id%>" method="post"
                          onsubmit="return confirmDelete(event)">
                        <button type="submit" class="btn-admin-delete">
                            <i class="fa-solid fa-trash"></i> Delete
                        </button>
                    </form>
                </div>
            </div>
            <p><i class="fa-solid fa-phone" style="color:var(--primary); margin-right:6px;"></i><%=contactDetails[i].number%></p>
            <p><i class="fa-solid fa-envelope" style="color:var(--primary); margin-right:6px;"></i><%=contactDetails[i].mail%></p>
            <div class="msg"><p><%=contactDetails[i].message%></p></div>
        </div>
    <% }; %>
    </div>
</div>

<!-- Confirmation Modal -->
<div id="deleteModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:var(--white); border-radius:var(--radius); padding:2rem 2.25rem; max-width:380px; width:90%; box-shadow:0 8px 32px rgba(0,0,0,0.18); text-align:center;">
        <i class="fa-solid fa-triangle-exclamation" style="font-size:2rem; color:#f97316; margin-bottom:0.75rem; display:block;"></i>
        <h3 style="color:var(--text); margin-bottom:0.5rem;">Delete Message?</h3>
        <p style="color:var(--text-muted); font-size:0.9rem; margin-bottom:1.5rem;">This action cannot be undone.</p>
        <div style="display:flex; gap:0.75rem; justify-content:center;">
            <button id="modalYes" style="background:#991b1b; color:#fff; border:none; border-radius:8px; padding:0.5rem 1.5rem; font-weight:700; font-size:0.92rem; cursor:pointer;">
                Yes, delete
            </button>
            <button id="modalNo" style="background:var(--bg); color:var(--text); border:1.5px solid var(--border); border-radius:8px; padding:0.5rem 1.5rem; font-weight:600; font-size:0.92rem; cursor:pointer;">
                Cancel
            </button>
        </div>
    </div>
</div>

<script>
var pendingForm = null;
var modal = document.getElementById('deleteModal');

function confirmDelete(e) {
    e.preventDefault();
    pendingForm = e.target;
    modal.style.display = 'flex';
    return false;
}

document.getElementById('modalYes').addEventListener('click', function() {
    modal.style.display = 'none';
    if (pendingForm) pendingForm.submit();
});

document.getElementById('modalNo').addEventListener('click', function() {
    modal.style.display = 'none';
    pendingForm = null;
});

modal.addEventListener('click', function(e) {
    if (e.target === modal) {
        modal.style.display = 'none';
        pendingForm = null;
    }
});
</script>

<%- include('partials/footer'); -%>
