<%- include('partials/admin'); -%>

<div class="page-content">
    <div class="compose">
        <h2><span><%= card ? 'Edit' : 'Add' %></span> Home Card</h2>
    </div>
    <div class="admin-form-card">
        <form action="<%= action %>" method="post">
            <div class="mb-3">
                <label class="form-label">Card Title</label>
                <input class="form-control pushi" type="text" name="cardTitle" placeholder="e.g. Design, Development, Research" value="<%= card ? card.title : '' %>" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea class="form-control" name="cardDescription" rows="4" placeholder="Brief description shown on the card..."><%= card ? card.description : '' %></textarea>
            </div>
            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label">Font Awesome Icon Class</label>
                        <input class="form-control" type="text" name="cardIcon" placeholder="e.g. fa-solid fa-code" value="<%= card ? card.icon : 'fa-solid fa-star' %>">
                        <p class="note" style="margin-top:0.4rem;"><i>Find icons at <a href="https://fontawesome.com/icons" target="_blank" style="color:var(--primary);">fontawesome.com/icons</a> — copy the class name.</i></p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label">Display Order</label>
                        <input class="form-control" type="number" name="cardOrder" placeholder="0" value="<%= card ? card.order : 0 %>">
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <div class="admin-checkbox-row">
                    <input type="checkbox" name="cardActive" id="cardActive" <%= !card || card.active ? 'checked' : '' %>>
                    <label for="cardActive">Show on home page (active)</label>
                </div>
            </div>
            <p class="note"><i><span>Note:</span> Hidden cards won't appear on the public home page.</i></p>
            <div class="admin-form-actions">
                <button class="btn btn-primary" type="submit"><%= card ? 'Update Card' : 'Add Card' %></button>
                <a href="/admin-homecards" class="admin-back-link">← Back to list</a>
            </div>
        </form>
    </div>
</div>

<%- include('partials/footer'); -%>
