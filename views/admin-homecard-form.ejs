<%- include('partials/admin'); -%>

<div class="page-content">
    <div class="compose">
        <h2><i class="fa-solid fa-rectangle-list me-2 text-primary"></i> <span><%= card ? 'Edit' : 'Add' %></span> Home Card</h2>
        <p class="text-muted">Design and reposition the highlight cards rendered under the homepage "What I Do" section.</p>
    </div>
    <div class="admin-form-card border rounded shadow-sm bg-white p-4">
        <form action="<%= action %>" method="post">
            <div class="mb-4">
                <label class="form-label d-flex align-items-center gap-2">
                    <i class="fa-solid fa-heading text-primary"></i> Card Title
                </label>
                <input class="form-control" type="text" name="cardTitle" placeholder="e.g. Design, Development, Research" value="<%= card ? card.title : '' %>" required>
                <small class="text-muted d-block mt-1">Brief header action or area of expertise.</small>
            </div>
            <div class="mb-4">
                <label class="form-label d-flex align-items-center gap-2">
                    <i class="fa-solid fa-paragraph text-primary"></i> Description
                </label>
                <textarea class="form-control" name="cardDescription" rows="4" placeholder="Brief description shown on the card..."><%= card ? card.description : '' %></textarea>
                <small class="text-muted d-block mt-1">One or two sentences summarizing these professional services.</small>
            </div>
            <div class="row">
                <div class="col-md-8 mb-4">
                    <label class="form-label d-flex align-items-center gap-2">
                        <i class="fa-solid fa-icons text-primary"></i> Font Awesome Icon Class
                    </label>
                    <input class="form-control" type="text" name="cardIcon" placeholder="e.g. fa-solid fa-code" value="<%= card ? card.icon : 'fa-solid fa-star' %>">
                    <small class="text-muted d-block mt-1">Find free icons on <a href="https://fontawesome.com/icons" target="_blank" class="text-decoration-none text-primary">fontawesome.com/icons</a> — copy-paste class name.</small>
                </div>
                <div class="col-md-4 mb-4">
                    <label class="form-label d-flex align-items-center gap-2">
                        <i class="fa-solid fa-sort-numeric-down text-primary"></i> Display Order
                    </label>
                    <input class="form-control" type="number" name="cardOrder" placeholder="0" value="<%= card ? card.order : 0 %>">
                    <small class="text-muted d-block mt-1">Ascending order index.</small>
                </div>
            </div>
            <div class="mb-4">
                <div class="admin-checkbox-row d-inline-flex align-items-center gap-2">
                    <input type="checkbox" name="cardActive" id="cardActive" <%= !card || card.active ? 'checked' : '' %>>
                    <label for="cardActive" class="user-select-none">Show on home page (active)</label>
                </div>
                <small class="text-muted d-block mt-1">Control visibility of this feature card instantly.</small>
            </div>
            <div class="note mb-4 p-3 bg-light border-start border-primary border-3 rounded">
                <p class="mb-0 text-muted">
                    <i class="fa-solid fa-circle-exclamation me-1 text-primary"></i> 
                    <strong>Note:</strong> Hidden cards won't appear on the public home page. Changes impact visual balance of the services grid.
                </p>
            </div>
            <div class="admin-form-actions d-flex align-items-center gap-3">
                <button class="btn btn-primary d-inline-flex align-items-center gap-2" type="submit">
                    <i class="fa-solid <%= card ? 'fa-check-double' : 'fa-plus' %>"></i>
                    <%= card ? 'Update Card' : 'Add Card' %>
                </button>
                <a href="/admin-homecards" class="admin-back-link text-decoration-none d-inline-flex align-items-center gap-1">
                    <i class="fa-solid fa-arrow-left"></i> Back to list
                </a>
            </div>
        </form>
    </div>
</div>

<%- include('partials/footer'); -%>
