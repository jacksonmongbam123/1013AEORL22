<%- include('partials/header'); -%>

<div class="page-content">
    <div class="compose">
        <h2><i class="fa-solid fa-magnifying-glass" style="color:var(--primary);font-size:1.4rem;margin-right:0.4rem;"></i><span>Search</span> Results</h2>
    </div>

    <!-- Search bar on results page -->
    <form action="/search" method="get" style="display:flex;gap:0.6rem;margin-bottom:2rem;max-width:520px;">
        <input class="form-control pushi" type="text" name="q" value="<%= query %>" placeholder="Search blog, learnings, careers...">
        <button class="btn btn-primary postbutton" type="submit" style="width:auto;white-space:nowrap;">Search</button>
    </form>

    <% if (query) { %>
        <p style="color:var(--text-muted);margin-bottom:1.5rem;">
            Showing results for <strong>"<%= query %>"</strong> —
            <strong><%= total %></strong> result<%= total !== 1 ? 's' : '' %> found
        </p>
    <% } %>

    <% if (total === 0 && query) { %>
        <div style="text-align:center;padding:3rem 0;color:var(--text-muted);">
            <i class="fa-solid fa-circle-exclamation" style="font-size:2rem;margin-bottom:0.75rem;display:block;"></i>
            No results found for "<%= query %>". Try a different keyword.
        </div>
    <% } %>

    <% if (blogs.length > 0) { %>
    <div style="margin-bottom:2rem;">
        <h4 style="margin-bottom:1rem;color:var(--text);"><i class="fa-solid fa-pen-to-square" style="color:var(--primary);margin-right:0.4rem;"></i>Blog Posts <span style="font-size:0.85rem;color:var(--text-muted);font-weight:400;">(<%= blogs.length %>)</span></h4>
        <% blogs.forEach(function(post) { %>
        <div class="result-card" style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:1.1rem 1.4rem;margin-bottom:0.85rem;box-shadow:var(--card-shadow);">
            <a href="/<%= encodeURIComponent(post.title) %>" style="text-decoration:none;">
                <strong style="font-size:1rem;color:var(--primary);"><%= post.title %></strong>
            </a>
            <p style="margin:0.35rem 0 0;font-size:0.88rem;color:var(--text-muted);"><%= post.content.substring(0,160).replace(/\n/g,' ') %>...</p>
            <span style="font-size:0.76rem;color:var(--text-muted);"><i class="fa-solid fa-calendar-days"></i> <%= post.timestamp %></span>
        </div>
        <% }); %>
    </div>
    <% } %>

    <% if (learnings.length > 0) { %>
    <div style="margin-bottom:2rem;">
        <h4 style="margin-bottom:1rem;color:var(--text);"><i class="fa-solid fa-lightbulb" style="color:var(--primary);margin-right:0.4rem;"></i>Learnings <span style="font-size:0.85rem;color:var(--text-muted);font-weight:400;">(<%= learnings.length %>)</span></h4>
        <% learnings.forEach(function(item) { %>
        <div class="result-card" style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:1.1rem 1.4rem;margin-bottom:0.85rem;box-shadow:var(--card-shadow);">
            <a href="/learnings" style="text-decoration:none;">
                <strong style="font-size:1rem;color:var(--primary);"><%= item.title %></strong>
            </a>
            <p style="margin:0.35rem 0 0;font-size:0.88rem;color:var(--text-muted);"><%= item.content.substring(0,160).replace(/\n/g,' ') %>...</p>
            <span style="font-size:0.76rem;color:var(--text-muted);"><i class="fa-solid fa-calendar-days"></i> <%= new Date(item.date).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'}) %></span>
        </div>
        <% }); %>
    </div>
    <% } %>

    <% if (careers.length > 0) { %>
    <div style="margin-bottom:2rem;">
        <h4 style="margin-bottom:1rem;color:var(--text);"><i class="fa-solid fa-briefcase" style="color:var(--primary);margin-right:0.4rem;"></i>Careers <span style="font-size:0.85rem;color:var(--text-muted);font-weight:400;">(<%= careers.length %>)</span></h4>
        <% careers.forEach(function(job) { %>
        <div class="result-card" style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:1.1rem 1.4rem;margin-bottom:0.85rem;box-shadow:var(--card-shadow);">
            <a href="/careers" style="text-decoration:none;">
                <strong style="font-size:1rem;color:var(--primary);"><%= job.title %></strong>
            </a>
            <p style="margin:0.35rem 0 0;font-size:0.88rem;color:var(--text-muted);"><%= job.description.substring(0,160).replace(/\n/g,' ') %>...</p>
            <span style="font-size:0.76rem;color:var(--text-muted);"><i class="fa-solid fa-location-dot"></i> <%= job.location %> &nbsp;·&nbsp; <i class="fa-solid fa-clock"></i> <%= job.type %></span>
        </div>
        <% }); %>
    </div>
    <% } %>
</div>

<%- include('partials/footer'); -%>
