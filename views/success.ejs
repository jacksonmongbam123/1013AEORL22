<%- include('partials/header') -%>

<div class="success-wrap">
    <div style="text-align:center; max-width:480px; width:100%;">
        <div style="background:#F0FDF4; border:1.5px solid #86EFAC; border-radius:var(--radius); padding:clamp(2rem,5vw,3rem) clamp(1.5rem,4vw,2.5rem);">
            <i class="fa-solid fa-circle-check" style="font-size:clamp(2.5rem,6vw,3.5rem); color:#16A34A; margin-bottom:1rem; display:block;"></i>
            <h2 style="color:#15803D; margin-bottom:0.75rem;">Message Sent!</h2>
            <p style="color:#166534; font-size:clamp(0.9rem,1.5vw,1rem); margin-bottom:1.75rem;">
                Thank you for reaching out — we will get back to you shortly.
            </p>
            <a href="/" style="text-decoration:none;">
                <button type="button" class="btn-auth" style="width:auto; padding:0.6rem 1.75rem; display:inline-block;">
                    Back to Home
                </button>
            </a>
        </div>
    </div>
</div>

<%- include('partials/footer') -%>
