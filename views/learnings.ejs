<%- include('partials/header'); -%>

<div class="page-content">
    <div class="blogtitle">
        <h2><span>Lear</span>nings</h2>
        <p style="color: var(--text-muted);">Notes, lessons, and things I have discovered.</p>
    </div>

    <% if(learn.length > 0) { %>
    <div class="filter-toolbar">
        <div class="search-bar">
            <i class="fa-solid fa-magnifying-glass search-icon"></i>
            <input
                type="text"
                id="learnSearch"
                class="search-input"
                placeholder="Search learnings by title..."
                autocomplete="off"
            />
            <button class="search-clear" id="learnClear" aria-label="Clear search">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="sort-wrap">
            <i class="fa-solid fa-arrow-up-wide-short sort-icon"></i>
            <select id="learnSort" class="sort-select">
                <option value="newest">Newest first</option>
                <option value="oldest">Oldest first</option>
                <option value="az">A → Z</option>
                <option value="za">Z → A</option>
            </select>
        </div>
    </div>
    <% } %>

    <% if(learn.length === 0) { %>
        <div class="about-card text-center py-5">
            <i class="fa-solid fa-book-open" style="font-size:2.5rem; color:var(--text-muted); margin-bottom:1rem;"></i>
            <p>No learnings posted yet. Check back soon!</p>
        </div>
    <% } %>

    <div class="cards-grid" id="learnGrid">
        <% for(var i=0; i<learn.length; i++) { %>
            <div class="learning-box"
                data-title="<%=learn[i].title.toLowerCase()%>"
                data-date="<%=new Date(learn[i].date).getTime()%>"
                data-title-raw="<%=learn[i].title%>">
                <h3><%=learn[i].title%></h3>
                <p><%=learn[i].content.substring(0, 400) + "..."%></p>
                <a class="btn-know">Know more</a>
            </div>
        <% } %>
    </div>

    <div class="search-empty" id="learnEmpty" style="display:none;">
        <i class="fa-solid fa-face-frown-open"></i>
        <p>No learnings match your search.</p>
    </div>
</div>

<script>
(function () {
    const input  = document.getElementById('learnSearch');
    const clear  = document.getElementById('learnClear');
    const sort   = document.getElementById('learnSort');
    const grid   = document.getElementById('learnGrid');
    const empty  = document.getElementById('learnEmpty');
    if (!input) return;

    function getCards() {
        return Array.from(grid.querySelectorAll('.learning-box'));
    }

    function applySort(cards, mode) {
        cards.sort(function (a, b) {
            if (mode === 'newest') return Number(b.dataset.date) - Number(a.dataset.date);
            if (mode === 'oldest') return Number(a.dataset.date) - Number(b.dataset.date);
            if (mode === 'az')     return a.dataset.titleRaw.localeCompare(b.dataset.titleRaw);
            if (mode === 'za')     return b.dataset.titleRaw.localeCompare(a.dataset.titleRaw);
            return 0;
        });
        cards.forEach(function (c) { grid.appendChild(c); });
    }

    function update() {
        const q    = input.value.trim().toLowerCase();
        const mode = sort.value;
        const cards = getCards();
        applySort(cards, mode);
        let visible = 0;
        cards.forEach(function (card) {
            const match = !q || card.dataset.title.includes(q);
            card.style.display = match ? '' : 'none';
            if (match) visible++;
        });
        clear.style.display = q ? 'flex' : 'none';
        empty.style.display = visible === 0 ? 'flex' : 'none';
    }

    input.addEventListener('input', update);
    sort.addEventListener('change', update);
    clear.addEventListener('click', function () {
        input.value = '';
        update();
        input.focus();
    });

    update();
})();
</script>

<%- include('partials/footer'); -%>
