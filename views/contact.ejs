<%- include('partials/header'); -%>

<div class="page-content">
    <div class="blogtitle">
        <h2><span>Con</span>tact</h2>
        <p style="color: var(--text-muted); font-size: clamp(0.875rem,1.5vw,1rem);">Have a question or want to work together? Send me a message.</p>
    </div>

    <div class="contact-card">
        <form action="/contact" method="post">
            <div class="mb-3">
                <label class="form-label">Name</label>
                <input class="form-control" type="text" name="contactName" placeholder="Your full name" required>
            </div>
            <div class="mb-3">
                <label class="form-label">E-mail</label>
                <input class="form-control" type="email" name="contactMail" placeholder="you@example.com" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Phone</label>
                <input class="form-control" type="number" name="contactNumber" placeholder="Your phone number">
            </div>
            <div class="mb-3">
                <label class="form-label">Message</label>
                <textarea class="form-control" name="contactMessage" rows="5" placeholder="Write your message here..."></textarea>
            </div>
            <button class="btn btn-primary postbutton w-100" type="submit">Send Message</button>
        </form>
    </div>
</div>

<%- include('partials/footer'); -%>
