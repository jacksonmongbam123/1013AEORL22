<%- include('partials/admin'); -%>

<div class="page-content">
    <div class="compose">
        <h2><span>Post</span> Blog</h2>
    </div>
    <div class="admin-form-card">
        <form action="/compose" method="post">
            <div class="mb-3">
                <label class="form-label">Blog Title</label>
                <input class="form-control pushi" type="text" name="postTitle" placeholder="Enter blog post title">
            </div>
            <div class="mb-3">
                <label class="form-label">Post Content</label>
                <textarea class="form-control" name="postBody" rows="8" placeholder="Write your blog post here..."></textarea>
            </div>
            <p class="note"><i><span>Note:</span> This is an admin page — only admins can make changes.</i></p>
            <button class="btn btn-primary postbutton" type="submit">Publish</button>
        </form>
    </div>
</div>

<%- include('partials/footer'); -%>
