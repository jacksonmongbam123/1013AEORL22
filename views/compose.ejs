<%- include('partials/admin'); -%>

<div class="page-content">
    <div class="page-header">
    <div class="page-header-content">
        <p class="page-label">Admin</p>
        <h1>Publish <span>Blog</span></h1>
        <p class="page-subtitle">Write and publish new blog posts or edit existing ones.</p>
    </div>
</div>
    <div class="admin-form-card">
        <form id="blogForm" action="<%= (typeof editItem !== 'undefined' && editItem) ? '/compose/edit/' + editItem._id : '/compose' %>" method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label">Blog Title</label>
                <input id="inputTitle" class="form-control pushi" type="text" name="postTitle"
                    placeholder="Enter blog post title"
                    value="<%= (typeof editItem !== 'undefined' && editItem) ? editItem.title : '' %>">
            </div>
            <div class="mb-3">
                <label class="form-label">Upload Cover Image</label>
                <input type="file" name="blogImage" id="blogImageInput" class="form-control pushi" accept="image/*" style="border-radius: 8px;">
                <div class="form-text text-muted" style="font-size: 0.8rem; margin-top: 0.25rem;">Supported formats: JPG, JPEG, PNG, GIF. Max size: 10MB.</div>
                <% if (typeof editItem !== 'undefined' && editItem && editItem.image) { %>
                    <div class="mt-2" style="display: flex; align-items: center; gap: 0.5rem;">
                        <span style="font-size: 0.85rem; color: var(--text-muted);">Current cover image:</span>
                        <img src="<%= editItem.image %>" alt="Cover Image" style="max-height: 50px; border-radius: 6px; border: 1px solid var(--border);">
                    </div>
                <% } %>
            </div>
            <div class="mb-3">
                <label class="form-label">Post Content</label>
                <textarea id="inputBody" class="form-control" name="postBody" rows="8"
                    placeholder="Write your blog post here..."><%= (typeof editItem !== 'undefined' && editItem) ? editItem.content : '' %></textarea>
            </div>
            <p class="note"><i><span>Note:</span> This is an admin page — only admins can make changes.</i></p>
            <div style="display:flex;flex-direction:row;align-items:center;gap:0.6rem;flex-wrap:nowrap;">
                <button class="btn btn-admin-style postbutton" type="submit" style="width:auto;margin:0;">
                    <i class="fa-regular fa-paper-plane me-1"></i> <%= (typeof editItem !== 'undefined' && editItem) ? 'Save Changes' : 'Publish' %>
                </button>
                <% if (typeof editItem !== 'undefined' && editItem) { %>
                <a href="/compose" class="btn-admin-cancel-style" style="width:auto;margin:0;"><i class="fa-solid fa-xmark me-1"></i> Cancel</a>
                <% } %>
            </div>
        </form>
    </div>

    <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
    <div class="page-header" style="margin-top:2.5rem;">
        <div class="page-header-content">
            <p class="page-label">All Posts</p>
            <h1>All <span>Blog Posts</span> <small style="font-size:1.1rem;font-weight:400;opacity:0.6;">(<%= posts.length %>)</small></h1>
        </div>
    </div>
    <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1.5rem;align-items:center;">
        <input id="searchInput" type="text" placeholder="🔍 Search by title or content..."
            class="form-control pushi" style="max-width:340px;" oninput="filterCards()">
        <select id="sortSelect" class="form-control" style="max-width:180px;" onchange="filterCards()">
            <option value="newest">Newest First</option>
            <option value="oldest">Oldest First</option>
            <option value="az">A → Z</option>
            <option value="za">Z → A</option>
        </select>
    </div>
    <div id="blogGrid">
    <% posts.forEach(function(item) { %>
    <div class="admin-form-card blog-card" style="margin-bottom:1.1rem;"
        data-title="<%= item.title.toLowerCase() %>"
        data-content="<%= item.content.toLowerCase() %>"
        data-date="<%= new Date(item.date).getTime() %>">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.5rem;margin-bottom:0.5rem;">
            <strong style="font-size:1.05rem;color:var(--text);"><%= item.title %></strong>
            <span style="font-size:0.78rem;color:var(--text-muted);white-space:nowrap;">
                <i class="fa-solid fa-calendar-days"></i>
                <%= item.timestamp %>
            </span>
        </div>
        <% if (item.image) { %>
            <div style="width: 100%; max-height: 120px; overflow: hidden; border-radius: 8px; margin-bottom: 0.75rem; border: 1px solid var(--border);">
                <img src="<%= item.image %>" alt="<%= item.title %>" style="width: 100%; height: 100%; object-fit: cover;">
            </div>
        <% } %>
        <p style="white-space:pre-wrap;color:var(--text-muted);margin-bottom:1rem;font-size:0.9rem;"><%= item.content.length > 200 ? item.content.substring(0,200)+'...' : item.content %></p>
        <div style="display:flex;flex-direction:row;align-items:center;gap:0.6rem;">
            <a href="/compose/edit/<%= item._id %>" class="btn btn-primary postbutton" style="width:auto;margin:0;font-size:0.85rem;padding:0.38rem 0.9rem;">
                <i class="fa-solid fa-pen"></i> Edit
            </a>
            <form action="/compose/delete/<%= item._id %>" method="post" style="margin:0;padding:0;"
                onsubmit="return confirm('Delete this blog post?');">
                <button class="btn btn-danger" type="submit" style="margin:0;font-size:0.85rem;padding:0.38rem 0.9rem;">
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </form>
        </div>
    </div>
    <% }); %>
    </div>
    <div id="noResults" style="display:none;text-align:center;color:var(--text-muted);padding:2rem;">
        <i class="fa-solid fa-magnifying-glass"></i> No posts match your search.
    </div>
    <% } else { %>
    <div class="admin-form-card" style="margin-top:2rem;color:#888;text-align:center;">
        <i class="fa-solid fa-circle-info"></i> No blog posts yet. Use the form above to publish one.
    </div>
    <% } %>
</div>

<script>
function filterCards() {
    const q = document.getElementById('searchInput').value.toLowerCase().trim();
    const sort = document.getElementById('sortSelect').value;
    const grid = document.getElementById('blogGrid');
    const cards = Array.from(grid ? grid.querySelectorAll('.blog-card') : []);
    let visible = cards.filter(c => !q || (c.dataset.title||'').includes(q) || (c.dataset.content||'').includes(q));
    cards.filter(c => !visible.includes(c)).forEach(c => c.style.display = 'none');
    visible.sort((a,b) => {
        if (sort==='newest') return Number(b.dataset.date)-Number(a.dataset.date);
        if (sort==='oldest') return Number(a.dataset.date)-Number(b.dataset.date);
        if (sort==='az') return (a.dataset.title||'').localeCompare(b.dataset.title||'');
        return (b.dataset.title||'').localeCompare(a.dataset.title||'');
    });
    visible.forEach(c => { c.style.display=''; grid.appendChild(c); });
    const nr = document.getElementById('noResults');
    if (nr) nr.style.display = visible.length===0 ? 'block' : 'none';
}
<% if (typeof editItem !== 'undefined' && editItem) { %>
window.addEventListener('DOMContentLoaded',function(){ document.getElementById('blogForm').scrollIntoView({behavior:'smooth'}); });
<% } %>
</script>

<%- include('partials/footer'); -%>
