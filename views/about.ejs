<%- include('partials/header'); -%>

<div class="page-content">

    <!-- Hero -->
    <div class="about-hero">
        <div class="about-hero-text">
            <p class="about-label">About me</p>
            <h1>Hi, I'm <span>Jackson Mongbam</span></h1>
            <p class="about-bio">
                <% if(homepage.length > 0) { %>
                    <%=homepage[0].about%>
                <% } else { %>
                    Developer, learner, and creator. Passionate about building things that matter.
                <% } %>
            </p>
            <div class="about-hero-links">
                <a href="/blog" class="btn-about-primary">Read my Blog</a>
                <a href="/contact" class="btn-about-outline">Get in touch</a>
            </div>
        </div>
        <div class="about-hero-img">
            <img src="img/about.png" alt="Jackson Mongbam" />
        </div>
    </div>

    <!-- Skills -->
    <div class="about-section">
        <h2 class="about-section-title"><span>Skills</span> &amp; Tech Stack</h2>
        <p class="about-section-sub">Tools and technologies I work with regularly.</p>

        <div class="skills-grid">

            <div class="skill-card">
                <div class="skill-icon"><i class="fa-brands fa-html5"></i></div>
                <h4>HTML5</h4>
                <p>Semantic markup, accessibility, and modern web structure.</p>
            </div>

            <div class="skill-card">
                <div class="skill-icon"><i class="fa-brands fa-css3-alt"></i></div>
                <h4>CSS3</h4>
                <p>Responsive design, Flexbox, Grid, animations, and custom properties.</p>
            </div>

            <div class="skill-card">
                <div class="skill-icon"><i class="fa-brands fa-js"></i></div>
                <h4>JavaScript</h4>
                <p>DOM manipulation, async/await, and building interactive experiences.</p>
            </div>

            <div class="skill-card">
                <div class="skill-icon"><i class="fa-brands fa-node-js"></i></div>
                <h4>Node.js</h4>
                <p>Server-side JavaScript, Express apps, and REST APIs.</p>
            </div>

            <div class="skill-card">
                <div class="skill-icon"><i class="fa-solid fa-database"></i></div>
                <h4>MongoDB</h4>
                <p>NoSQL database design, Mongoose schemas, and cloud data with Atlas.</p>
            </div>

            <div class="skill-card">
                <div class="skill-icon"><i class="fa-brands fa-git-alt"></i></div>
                <h4>Git &amp; GitHub</h4>
                <p>Version control, branching, collaboration, and open-source contribution.</p>
            </div>

            <div class="skill-card">
                <div class="skill-icon"><i class="fa-brands fa-bootstrap"></i></div>
                <h4>Bootstrap</h4>
                <p>Rapid responsive layouts with Bootstrap 5 components and utilities.</p>
            </div>

            <div class="skill-card">
                <div class="skill-icon"><i class="fa-solid fa-server"></i></div>
                <h4>Express.js</h4>
                <p>Routing, middleware, session management, and MVC architecture.</p>
            </div>

            <div class="skill-card">
                <div class="skill-icon"><i class="fa-solid fa-code"></i></div>
                <h4>EJS</h4>
                <p>Dynamic templating, partial views, and server-side rendering.</p>
            </div>

        </div>
    </div>

</div>

<%- include('partials/footer'); -%>
