<%- include('partials/admin'); -%>

<div class="page-content">
    <div class="compose">
        <h2><span>Post</span> Learnings</h2>
    </div>
    <div class="admin-form-card">
        <form action="/postlearnings" method="post">
            <div class="mb-3">
                <label class="form-label">Learnings Title</label>
                <input class="form-control pushi" type="text" name="learningsTitle" placeholder="Enter the learning title">
            </div>
            <div class="mb-3">
                <label class="form-label">Learnings Description</label>
                <textarea class="form-control" name="learningsBody" rows="6" placeholder="Describe what you learned..."></textarea>
            </div>
            <p class="note"><i><span>Note:</span> This is an admin page — only admins can make changes.</i></p>
            <button class="btn btn-primary postbutton" type="submit">Post Learnings</button>
        </form>
    </div>
</div>

<%- include('partials/footer'); -%>
