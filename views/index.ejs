<%- include('partials/header'); -%>

<!-- HERO -->
<section class="hero-section">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-lg-6 hero-text" style="padding: 3% 2%;">
                <% for(var i=0; i<homepage.length; i++) { %>
                    <h1><%=homepage[i].title%></h1>
                <% }; %>
                <p class="subtitle">A <span>Pro</span>grammer &amp; Developer</p>
                <a href="/maintenance">
                    <button type="button" class="btn btn-dark btn-lg download-button">Book</button>
                </a>
                <a href="/learnings">
                    <button type="button" class="btn btn-outline-dark btn-lg download-button">Explore more</button>
                </a>
            </div>
            <div class="col-lg-6 homeimage text-center">
                <img src="img/mountain.png" alt="Hero illustration" class="img-fluid">
            </div>
        </div>
    </div>
</section>

<!-- ABOUT PREVIEW -->
<section id="about">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-lg-5 homeimage text-center mb-4 mb-lg-0">
                <img src="img/about.png" alt="About illustration" class="img-fluid" style="max-width:380px; border-radius:12px;">
            </div>
            <div class="col-lg-7 hawert">
                <h2>About <span>This Site</span></h2>
                <% for(var i=0; i<homepage.length; i++) { %>
                    <p><%=homepage[i].about.substring(0, 300) + "..."%></p>
                <% }; %>
                <a href="/about" class="btn-read-more">Read more</a>
            </div>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section id="features">
    <div class="container-fluid">
        <h2 style="text-align:center; margin-bottom:2rem;">What I <span>Do</span></h2>
        <div class="row">
            <div class="col-lg-4 col-md-6 mb-3">
                <div class="feature-box">
                    <i class="fa-sharp fa-solid fa-crop-simple"></i>
                    <h3>Design</h3>
                    <p>Creating beautiful, user-focused interfaces that look great on every device.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-3">
                <div class="feature-box">
                    <i class="fa-solid fa-code"></i>
                    <h3>Development</h3>
                    <p>Building robust web applications with modern technologies and best practices.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-3">
                <div class="feature-box">
                    <i class="fa-brands fa-aws"></i>
                    <h3>Hosting</h3>
                    <p>Deploying and maintaining applications on reliable cloud infrastructure.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-3">
                <div class="feature-box">
                    <i class="fa-solid fa-server"></i>
                    <h3>Server</h3>
                    <p>Configuring and managing server environments for optimal performance.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-3">
                <div class="feature-box">
                    <i class="fa-solid fa-people-roof"></i>
                    <h3>Management</h3>
                    <p>Coordinating projects and teams to deliver results on time and on scope.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-3">
                <div class="feature-box">
                    <i class="fa-solid fa-network-wired"></i>
                    <h3>Network Operations</h3>
                    <p>Managing networking infrastructure for connectivity and security.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SLIDER -->
<section id="slider">
    <div class="container-fluid py-4">
        <div id="ideaslider" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <h1>Have an idea?</h1>
                    <img class="image" src="img/concept.png" alt="Concept">
                </div>
                <div class="carousel-item">
                    <h1>Have a meet!</h1>
                    <img class="image1" src="img/meeting.png" alt="Meeting">
                </div>
                <div class="carousel-item">
                    <h1>Make it a reality</h1>
                    <img class="image3" src="img/app.png" alt="App">
                </div>
                <div class="carousel-item">
                    <h1>Technology we use</h1>
                    <img class="image2" src="img/technology.png" alt="Technology">
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#ideaslider" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#ideaslider" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </div>
</section>

<%- include('partials/footer'); -%>
