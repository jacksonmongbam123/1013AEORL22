<%- include('partials/header'); -%>

<div class="page-content">
    <div class="blogtitle">
        <h2><span>B</span>log</h2>
        <p style="color: var(--text-muted);">Thoughts, tutorials, and stories.</p>
    </div>

    <% if(postuser.length === 0) { %>
        <div class="about-card text-center py-5">
            <i class="fa-solid fa-newspaper" style="font-size:2.5rem; color:var(--text-muted); margin-bottom:1rem;"></i>
            <p>No blog posts yet. Check back soon!</p>
        </div>
    <% } %>

    <% for(var i=0; i<postuser.length; i++) { %>
        <div class="blogcard">
            <div class="blogti">
                <h3><%=postuser[i].title%></h3>
                <label><%=postuser[i].timestamp%></label>
            </div>
            <p><%=postuser[i].content.substring(0, 400) + "..."%>
                <a href="/<%=postuser[i].title%>"> Read more</a>
            </p>
        </div>
    <% } %>
</div>

<%- include('partials/footer'); -%>
