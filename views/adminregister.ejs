<%- include('partials/header'); -%>

<style>
.auth-split-wrapper{display:flex;min-height:100vh;margin:0;padding:0;align-items:stretch;background:var(--bg,#f9fafb);}
.auth-info-panel{flex:0 0 420px;display:flex;align-items:center;justify-content:center;padding:3rem 2.5rem;background:#fff;}
.auth-info-card{background:#f0fdf4;border:1.5px solid #bbf7d0;border-radius:16px;padding:2.25rem 2rem;width:100%;max-width:340px;box-shadow:0 2px 16px rgba(16,185,129,0.07);}
.auth-info-card .info-icon{width:52px;height:52px;background:#dcfce7;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem;}
.auth-info-card .info-icon i{font-size:1.4rem;color:#059669;}
.auth-info-card h3{font-size:1.1rem;font-weight:700;color:#1a3a2a;margin-bottom:0.35rem;}
.auth-info-card .info-sub{font-size:0.83rem;color:#3d6a50;margin-bottom:1.5rem;line-height:1.55;}
.auth-info-card ul{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.65rem;}
.auth-info-card ul li{display:flex;align-items:flex-start;gap:0.65rem;font-size:0.83rem;color:#1f4d35;line-height:1.5;}
.auth-info-card ul li i{color:#059669;font-size:0.8rem;margin-top:0.2rem;flex-shrink:0;}
.auth-info-card .info-note{margin-top:1.5rem;padding-top:1rem;border-top:1px solid #bbf7d0;font-size:0.75rem;color:#3d6a50;display:flex;align-items:flex-start;gap:0.5rem;line-height:1.5;}
.auth-info-card .info-note i{color:#059669;font-size:0.8rem;margin-top:0.15rem;flex-shrink:0;}
.auth-form-panel{flex:1;display:flex;align-items:center;justify-content:center;padding:3rem 2.5rem;}
.auth-form-panel .auth-card{max-width:420px;width:100%;}
@media(max-width:900px){.auth-split-wrapper{flex-direction:column;}.auth-info-panel{flex:0 0 auto;padding:2rem 1.5rem;}.auth-info-card{max-width:100%;}.auth-form-panel{padding:2rem 1.25rem;}}
</style>

<div class="auth-split-wrapper">
    <div class="auth-info-panel">
        <div class="auth-info-card">
            <div class="info-icon">
                <i class="fa-solid fa-user-shield"></i>
            </div>
            <h3>Admin Registration</h3>
            <p class="info-sub">Create your admin account. Make sure you have your Admin ID before proceeding.</p>
            <ul>
                <li><i class="fa-solid fa-circle-check"></i>Obtain a valid Admin ID from the system admin</li>
                <li><i class="fa-solid fa-circle-check"></i>Use an official email address</li>
                <li><i class="fa-solid fa-circle-check"></i>Set a strong password (min 8 characters)</li>
                <li><i class="fa-solid fa-circle-check"></i>Verify credentials with the admin team</li>
            </ul>
            <div class="info-note">
                <i class="fa-solid fa-info-circle"></i>
                <span>Contact the admin team to receive your Admin ID before registering.</span>
            </div>
        </div>
    </div>
    <div class="auth-form-panel">
        <div class="auth-card">
            <h2>Admin <span>Register</span></h2>
            <form action="/adminregister" method="post">
                <div class="form-group">
                    <label>Admin ID</label>
                    <input type="text" name="adminid" placeholder="Enter admin ID" required>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="username" placeholder="admin@example.com" required>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="Create a password" required>
                </div>
                <button type="submit" class="btn-auth">Register</button>
                <p class="auth-link">Already have an account? <a href="/adminlogin">Sign in</a></p>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer'); -%>
