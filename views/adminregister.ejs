<%- include('partials/header'); -%>

<style>
.auth-wrapper{display:flex;min-height:100vh;margin:0;padding:0;align-items:center;justify-content:center;background:var(--bg,#f9fafb);}
.auth-wrapper .auth-card{max-width:420px;width:100%;padding:3rem 2.5rem;}
@media(max-width:768px){.auth-wrapper{padding:2rem 1.25rem;}.auth-wrapper .auth-card{padding:2rem 1.25rem;}}
</style>

<div class="auth-wrapper">
    <div class="auth-card">
            <h2>Admin <span>Register</span></h2>
            <form action="/adminregister" method="post">
                <div class="form-group">
                    <label>Admin ID</label>
                    <input type="text" name="adminid" placeholder="Enter admin ID" required>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="username" placeholder="admin@example.com" required>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="Create a password" required>
                </div>
                <button type="submit" class="btn-auth">Register</button>
                <p class="auth-link">Already have an account? <a href="/adminlogin">Sign in</a></p>
            </form>
    </div>
</div>

<%- include('partials/footer'); -%>
