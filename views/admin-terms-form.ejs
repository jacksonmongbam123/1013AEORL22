<%- include('partials/admin'); -%>

<div class="page-content">
    <div class="compose">
        <h2><span><%= terms ? 'Edit' : 'Add' %></span> Terms Section</h2>
    </div>
    <div class="admin-form-card">
        <form action="<%= action %>" method="post">
            <div class="mb-3">
                <label class="form-label">Section Title</label>
                <input class="form-control pushi" type="text" name="termsTitle" placeholder="e.g. Intellectual Property, User Conduct..." value="<%= terms ? terms.title : '' %>" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Section Content</label>
                <textarea class="form-control" name="termsContent" rows="10" placeholder="Write the terms content for this section..." required><%= terms ? terms.content : '' %></textarea>
            </div>
            <p class="note"><i><span>Note:</span> Each section appears as a separate block on the public Terms of Use page.</i></p>
            <div class="admin-form-actions">
                <button class="btn btn-primary" type="submit"><%= terms ? 'Update Section' : 'Add Section' %></button>
                <a href="/admin-terms" class="admin-back-link">← Back to list</a>
            </div>
        </form>
    </div>
</div>

<%- include('partials/footer'); -%>
