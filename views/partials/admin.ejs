<%- include('header'); -%>
<nav class="admin-navbar">
    <a class="admin-brand" href="/loggedin">
        <i class="fa-solid fa-shield-halved"></i>
        <span>Admin</span> Panel
    </a>
    <div class="admin-nav-links">
        <a href="/edithome"><i class="fa-solid fa-house-pen"></i> Update Home</a>
        <a href="/postlearnings"><i class="fa-solid fa-lightbulb"></i> Post Learnings</a>
        <a href="/compose"><i class="fa-solid fa-pen-to-square"></i> Publish Blog</a>
        <a href="/getcontact"><i class="fa-solid fa-envelope"></i> Get Contacts</a>
    </div>
</nav>
<script>
    (function () {
        var path = window.location.pathname;
        document.querySelectorAll('.admin-nav-links a').forEach(function (link) {
            if (new URL(link.href).pathname === path) {
                link.classList.add('active');
            }
        });
    })();
</script>
