<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- ── Google Search Console Verification ── -->
    <meta name="google-site-verification" content="jrxpfIHtHQpurXk13E-0jgr2-w293cuTl-BevOJVP1U" />

    <!-- ── Primary SEO ── -->
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Jackson Mongbam — Developer & Programmer' %></title>
    <meta name="description" content="<%= typeof pageDesc !== 'undefined' ? pageDesc : 'Personal blog and portfolio of Jackson Mongbam — a programmer and developer sharing thoughts, tutorials, and learnings.' %>">
    <meta name="author" content="Jackson Mongbam">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="<%= typeof pageUrl !== 'undefined' ? pageUrl : siteUrl %>">

    <!-- ── Open Graph ── -->
    <meta property="og:type" content="<%= typeof ogType !== 'undefined' ? ogType : 'website' %>">
    <meta property="og:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle : 'Jackson Mongbam — Developer & Programmer' %>">
    <meta property="og:description" content="<%= typeof pageDesc !== 'undefined' ? pageDesc : 'Personal blog and portfolio of Jackson Mongbam — a programmer and developer sharing thoughts, tutorials, and learnings.' %>">
    <meta property="og:url" content="<%= typeof pageUrl !== 'undefined' ? pageUrl : siteUrl %>">
    <meta property="og:site_name" content="Jackson Mongbam">
    <meta property="og:image" content="<%= siteUrl %>/img/about.png">
    <meta property="og:locale" content="en_US">

    <!-- ── Twitter Card ── -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle : 'Jackson Mongbam — Developer & Programmer' %>">
    <meta name="twitter:description" content="<%= typeof pageDesc !== 'undefined' ? pageDesc : 'Personal blog and portfolio of Jackson Mongbam — a programmer and developer sharing thoughts, tutorials, and learnings.' %>">
    <meta name="twitter:image" content="<%= siteUrl %>/img/about.png">

    <!-- ── JSON-LD: Person (all pages) ── -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Jackson Mongbam",
        "url": "<%= siteUrl %>",
        "description": "Programmer and developer sharing thoughts, tutorials, and learnings.",
        "knowsAbout": ["Web Development", "Node.js", "JavaScript", "MongoDB", "Express.js"]
    }
    </script>
    <% if (typeof postTitle !== 'undefined') { %>
    <!-- ── JSON-LD: BlogPosting (individual post pages) ── -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": "<%= postTitle.replace(/\\/g, '\\\\').replace(/"/g, '\\"') %>",
        "author": { "@type": "Person", "name": "Jackson Mongbam" },
        "publisher": { "@type": "Person", "name": "Jackson Mongbam" },
        "url": "<%= typeof pageUrl !== 'undefined' ? pageUrl : siteUrl %>"
    }
    </script>
    <% } %>

    <!-- ── Stylesheets & Scripts ── -->
    <link rel="icon" type="image/svg+xml" href="/img/favicon.svg">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-iYQeCzEYFbKjA/T2uDLTpkwGzCiq6soy8tYaI1GyVh/UjpbCx/TYkiZhlZB6+fzT" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/js/bootstrap.bundle.min.js" integrity="sha384-u1OknCvxWvY5kfmNBILK2hRnQC3Pr17a+RTT6rIHI7NnikvbZlHgTPOOmMi466C8" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<section id="title">
    <div class="container-fluid">
        <nav class="navbar navbar-expand-lg navbar-custom">
            <a class="navbar-brand" href="/"><strong>Jackson <span>Mongbam</span></strong></a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto">
                    <li class="navbar-item search-nav-item">
                        <div class="navbar-search-container">
                            <form class="navbar-search-form" action="/search" method="get" role="search">
                                <input class="navbar-search-input" type="search" name="q" placeholder="Search..." aria-label="Search"
                                    value="<%= typeof query !== 'undefined' ? query : '' %>" autocomplete="off">
                                <button class="navbar-search-btn" type="submit">
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                </button>
                            </form>
                            <div id="search-results-dropdown" class="search-results-dropdown"></div>
                        </div>
                    </li>
                    <li class="navbar-item">
                        <a class="nav-link" href="/"><i class="fa-solid fa-house"></i> Home</a>
                    </li>
                    <li class="navbar-item">
                        <a class="nav-link" href="/learnings"><i class="fa-solid fa-book"></i> Learnings</a>
                    </li>
                    <li class="navbar-item">
                        <a class="nav-link" href="/blog"><i class="fa-solid fa-pen-nib"></i> Blog</a>
                    </li>
                    <li class="navbar-item">
                        <a class="nav-link" href="/about"><i class="fa-solid fa-circle-info"></i> About</a>
                    </li>
                    <li class="navbar-item">
                        <a class="nav-link" href="/contact"><i class="fa-solid fa-envelope"></i> Contact</a>
                    </li>
                </ul>
            </div>
        </nav>

        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const searchInput = document.querySelector('.navbar-search-input');
                const resultsDropdown = document.getElementById('search-results-dropdown');
                let debounceTimer;

                if (searchInput && resultsDropdown) {
                    searchInput.addEventListener('input', function() {
                        clearTimeout(debounceTimer);
                        const query = this.value.trim();

                        if (query.length < 2) {
                            resultsDropdown.style.display = 'none';
                            return;
                        }

                        debounceTimer = setTimeout(() => {
                            fetch(`/api/search?q=${encodeURIComponent(query)}`)
                                .then(response => response.json())
                                .then(data => {
                                    resultsDropdown.innerHTML = '';
                                    let hasResults = false;

                                    const sections = [
                                        { title: 'Blog Posts', items: data.blogs, icon: 'fa-pen-nib' },
                                        { title: 'Learnings', items: data.learnings, icon: 'fa-book' },
                                        { title: 'Careers', items: data.careers, icon: 'fa-briefcase' }
                                    ];

                                    sections.forEach(section => {
                                        if (section.items && section.items.length > 0) {
                                            hasResults = true;
                                            const header = document.createElement('div');
                                            header.className = 'search-dropdown-header';
                                            header.innerHTML = `<i class="fa-solid ${section.icon}"></i> ${section.title}`;
                                            resultsDropdown.appendChild(header);

                                            section.items.forEach(item => {
                                                const link = document.createElement('a');
                                                link.className = 'search-dropdown-item';
                                                link.href = section.title === 'Blog Posts' ? `/${encodeURIComponent(item.title)}` : 
                                                            (section.title === 'Learnings' ? '/learnings' : '/careers');
                                                link.textContent = item.title;
                                                resultsDropdown.appendChild(link);
                                            });
                                        }
                                    });

                                    if (hasResults) {
                                        resultsDropdown.style.display = 'block';
                                    } else {
                                        resultsDropdown.innerHTML = '<div class="search-dropdown-item no-results">No results found</div>';
                                        resultsDropdown.style.display = 'block';
                                    }
                                });
                        }, 300);
                    });

                    document.addEventListener('click', function(e) {
                        if (!searchInput.contains(e.target) && !resultsDropdown.contains(e.target)) {
                            resultsDropdown.style.display = 'none';
                        }
                    });
                }
            });
        </script>
    </div>
</section>
