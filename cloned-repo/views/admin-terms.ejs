<%- include('partials/admin'); -%>

<div class="page-content">
    <div class="blogtitle" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem;">
        <div>
            <h2><span>Manage</span> Terms of Use</h2>
            <p style="color:var(--text-muted); margin:0;">Each entry becomes a section on the public Terms page.</p>
        </div>
        <a href="/admin-terms/add" class="btn btn-primary" style="display:inline-flex; align-items:center; gap:0.5rem; text-decoration:none;">
            <i class="fa-solid fa-plus"></i> Add Section
        </a>
    </div>

    <% if (termsList.length === 0) { %>
    <div class="about-card text-center py-5">
        <i class="fa-solid fa-file-contract" style="font-size:2.5rem; color:var(--text-muted); margin-bottom:1rem;"></i>
        <p>No terms sections yet. <a href="/admin-terms/add" style="color:var(--primary); font-weight:600;">Add one</a></p>
    </div>
    <% } %>

    <div style="display:flex; flex-direction:column; gap:1rem;">
    <% for(var i=0; i<termsList.length; i++) { %>
    <div class="blogcard" style="display:flex; justify-content:space-between; align-items:flex-start; gap:1rem; flex-wrap:wrap;">
        <div style="flex:1; min-width:200px;">
            <h3 style="color:var(--text); font-size:clamp(1rem,2vw,1.15rem); margin-bottom:0.4rem;"><%= termsList[i].title %></h3>
            <p style="color:var(--text-muted); font-size:0.88rem; margin-bottom:0.3rem; white-space:pre-wrap;"><%= termsList[i].content.substring(0,150) %><%= termsList[i].content.length > 150 ? '...' : '' %></p>
            <% if(termsList[i].lastUpdated) { %>
            <p style="font-size:0.78rem; color:var(--text-muted); margin:0;">
                <i class="fa-regular fa-clock"></i> <%= new Date(termsList[i].lastUpdated).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'}) %>
            </p>
            <% } %>
        </div>
        <div style="display:flex; gap:0.5rem; align-items:center; flex-shrink:0;">
            <a href="/admin-terms/edit/<%= termsList[i]._id %>" class="btn btn-sm" style="background:var(--primary-light); color:var(--primary); border:1px solid var(--primary); font-weight:600; font-size:0.82rem; padding:0.3rem 0.8rem; border-radius:6px; text-decoration:none; display:inline-flex; align-items:center; gap:0.3rem;">
                <i class="fa-solid fa-pen"></i> Edit
            </a>
            <form action="/admin-terms/delete/<%= termsList[i]._id %>" method="post" onsubmit="return confirm('Delete this terms section?')">
                <button type="submit" class="btn btn-sm" style="background:#fee2e2; color:#991b1b; border:1px solid #fca5a5; font-weight:600; font-size:0.82rem; padding:0.3rem 0.8rem; border-radius:6px; display:inline-flex; align-items:center; gap:0.3rem;">
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </form>
        </div>
    </div>
    <% } %>
    </div>
</div>

<%- include('partials/footer'); -%>
