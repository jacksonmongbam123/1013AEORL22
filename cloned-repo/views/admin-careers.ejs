<%- include('partials/admin'); -%>

<div class="page-content">
    <div class="blogtitle" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem;">
        <div>
            <h2><span>Manage</span> Careers</h2>
            <p style="color:var(--text-muted); margin:0;">All career listings in the database.</p>
        </div>
        <a href="/admin-careers/add" class="btn btn-primary" style="display:inline-flex; align-items:center; gap:0.5rem; text-decoration:none;">
            <i class="fa-solid fa-plus"></i> Add Career
        </a>
    </div>

    <% if (careers.length === 0) { %>
    <div class="about-card text-center py-5">
        <i class="fa-solid fa-briefcase" style="font-size:2.5rem; color:var(--text-muted); margin-bottom:1rem;"></i>
        <p>No career listings yet. <a href="/admin-careers/add" style="color:var(--primary); font-weight:600;">Add one</a></p>
    </div>
    <% } %>

    <div style="display:flex; flex-direction:column; gap:1rem;">
    <% for(var i=0; i<careers.length; i++) { %>
    <div class="blogcard" style="display:flex; justify-content:space-between; align-items:flex-start; gap:1rem; flex-wrap:wrap;">
        <div style="flex:1; min-width:200px;">
            <div style="display:flex; align-items:center; gap:0.6rem; margin-bottom:0.5rem; flex-wrap:wrap;">
                <span style="background:var(--primary-light); color:var(--primary); padding:0.15rem 0.7rem; border-radius:20px; font-size:0.78rem; font-weight:700;"><%= careers[i].type %></span>
                <span style="background:<%= careers[i].active ? '#dcfce7' : '#fee2e2' %>; color:<%= careers[i].active ? '#166534' : '#991b1b' %>; padding:0.15rem 0.7rem; border-radius:20px; font-size:0.78rem; font-weight:700;">
                    <%= careers[i].active ? 'Active' : 'Inactive' %>
                </span>
            </div>
            <h3 style="color:var(--text); font-size:clamp(1rem,2vw,1.15rem); margin-bottom:0.3rem;"><%= careers[i].title %></h3>
            <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:0.25rem;">
                <% if(careers[i].location){ %><i class="fa-solid fa-location-dot" style="color:var(--primary);"></i> <%= careers[i].location %>&nbsp;&nbsp;<% } %>
                <% if(careers[i].salary){ %><i class="fa-solid fa-money-bill-wave" style="color:var(--primary);"></i> <%= careers[i].salary %>&nbsp;&nbsp;<% } %>
                <% if(careers[i].deadline){ %><i class="fa-solid fa-clock" style="color:var(--primary);"></i> <%= careers[i].deadline %><% } %>
            </p>
            <p style="color:var(--text-muted); font-size:0.88rem; margin:0; white-space:pre-wrap;"><%= careers[i].description.substring(0,120) %><%= careers[i].description.length > 120 ? '...' : '' %></p>
        </div>
        <div style="display:flex; gap:0.5rem; align-items:center; flex-shrink:0;">
            <a href="/admin-careers/edit/<%= careers[i]._id %>" class="btn btn-sm" style="background:var(--primary-light); color:var(--primary); border:1px solid var(--primary); font-weight:600; font-size:0.82rem; padding:0.3rem 0.8rem; border-radius:6px; text-decoration:none; display:inline-flex; align-items:center; gap:0.3rem;">
                <i class="fa-solid fa-pen"></i> Edit
            </a>
            <form action="/admin-careers/delete/<%= careers[i]._id %>" method="post" onsubmit="return confirm('Delete this career listing?')">
                <button type="submit" class="btn btn-sm" style="background:#fee2e2; color:#991b1b; border:1px solid #fca5a5; font-weight:600; font-size:0.82rem; padding:0.3rem 0.8rem; border-radius:6px; display:inline-flex; align-items:center; gap:0.3rem;">
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </form>
        </div>
    </div>
    <% } %>
    </div>
</div>

<%- include('partials/footer'); -%>
