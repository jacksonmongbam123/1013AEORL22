<%- include('partials/header'); -%>

<div class="auth-wrapper">
    <div class="auth-card">
        <div style="text-align:center; margin-bottom:1.75rem;">
            <i class="fa-solid fa-shield-halved" style="font-size:2.5rem; color:var(--primary); margin-bottom:0.75rem; display:block;"></i>
            <h2>Admin <span>Panel</span></h2>
            <p style="color:var(--text-muted); font-size:clamp(0.83rem,1.3vw,0.9rem); margin-top:0.25rem;">Choose an option to continue</p>
        </div>
        <div class="auth-btn-row">
            <a href="/adminregister">
                <button type="button" class="btn-auth">Register</button>
            </a>
            <a href="/adminlogin">
                <button type="button" class="btn-auth btn-auth--login">Login</button>
            </a>
        </div>
    </div>
</div>

<%- include('partials/footer'); -%>
